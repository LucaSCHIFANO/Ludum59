      m_Calls: []
  m_text: "You have to help a small battery-robot to reach its destination.\r\nHowever,
    it is in an underground laboratory and does not have good reception.\r\nYou must
    then send all the necessary inputs at once.\r\n\r\nLook at the level and when
    you\u2019re ready, press Start/Enter.\r\nAll your inputs will then be recorded
    up to 100 seconds.\r\nOnce finished, press again Start/Enter to watch the robot
    move.\r\n\r\nEach color segment indicates how long it takes to cross it. Use
    this, as well as the metronome that will make a noise every second.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
